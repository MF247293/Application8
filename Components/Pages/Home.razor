@page "/"
@rendermode InteractiveServer

<div class="home-bg">
    <div class="home-topbar">
        <span class="home-title">Dashboard</span>
        <span class="db-badge">SQL Server Connected</span>
    </div>

    <div class="home-content">
        <div class="welcome-card">
            <div class="welcome-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#4a90e2" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <polyline points="9 11 12 14 22 4"/>
                </svg>
            </div>
            <h1 class="welcome-heading">Welcome to Application 08</h1>
            <p class="welcome-sub">A Blazor Server ToDo app connected to SQL Server LocalDB</p>
            <a href="/todo" class="go-btn">Go to To-Do List →</a>
        </div>

        <div class="info-grid">
            <div class="info-card">
                <div class="info-icon" style="background:#e8f0fe;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4a90e2" stroke-width="2">
                        <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                    </svg>
                </div>
                <div class="info-label">Database</div>
                <div class="info-value">SQL Server LocalDB</div>
            </div>
            <div class="info-card">
                <div class="info-icon" style="background:#e8f5e9;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2">
                        <polyline points="9 11 12 14 22 4"/>
                        <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                    </svg>
                </div>
                <div class="info-label">Framework</div>
                <div class="info-value">Blazor Server .NET 8</div>
            </div>
            <div class="info-card">
                <div class="info-icon" style="background:#fce8e8;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <div class="info-label">ORM</div>
                <div class="info-value">Entity Framework Core 8</div>
            </div>
        </div>

        <div class="feature-card">
            <h3 class="feature-heading">Features</h3>
            <div class="feature-list">
                <div class="feature-item">
                    <span class="dot green"></span>
                    Two-way binding captures task input in real time
                </div>
                <div class="feature-item">
                    <span class="dot blue"></span>
                    One-way binding displays the task list
                </div>
                <div class="feature-item">
                    <span class="dot green"></span>
                    Add, complete, delete, and clear tasks
                </div>
                <div class="feature-item">
                    <span class="dot blue"></span>
                    All changes saved to SQL Server database
                </div>
                <div class="feature-item">
                    <span class="dot green"></span>
                    Data persists after browser refresh
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .home-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #f0f4ff 0%, #e8f5e9 100%);
    }
    .home-topbar {
        background: rgba(255,255,255,0.9);
        padding: 14px 28px;
        border-bottom: 1px solid rgba(0,0,0,0.07);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .home-title {
        font-size: 17px;
        font-weight: 600;
        color: #1a1a2e;
    }
    .db-badge {
        background: #4a90e2;
        color: white;
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 20px;
    }
    .home-content {
        padding: 32px 28px;
        max-width: 860px;
        margin: 0 auto;
    }
    .welcome-card {
        background: white;
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        border: 1px solid rgba(0,0,0,0.06);
        margin-bottom: 20px;
    }
    .welcome-icon { margin-bottom: 16px; }
    .welcome-heading {
        font-size: 24px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 8px;
    }
    .welcome-sub {
        color: #888;
        font-size: 15px;
        margin-bottom: 24px;
    }
    .go-btn {
        display: inline-block;
        background: #4a90e2;
        color: white;
        padding: 12px 28px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 15px;
        font-weight: 500;
        transition: background 0.2s;
    }
    .go-btn:hover { background: #357abd; color: white; }
    .info-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 14px;
        margin-bottom: 20px;
    }
    .info-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid rgba(0,0,0,0.06);
        text-align: center;
    }
    .info-icon {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
    }
    .info-label {
        font-size: 12px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }
    .info-value {
        font-size: 14px;
        font-weight: 600;
        color: #1a1a2e;
    }
    .feature-card {
        background: white;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid rgba(0,0,0,0.06);
    }
    .feature-heading {
        font-size: 16px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 16px;
    }
    .feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        font-size: 14px;
        color: #444;
        border-bottom: 1px solid #f5f5f5;
    }
    .feature-item:last-child { border-bottom: none; }
    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .dot.green { background: #27ae60; }
    .dot.blue { background: #4a90e2; }
</style>