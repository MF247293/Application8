@page "/todo"
@rendermode InteractiveServer
@using Application08_TodoDB.Models
@using Application08_TodoDB.Data
@inject AppDbContext Db

<div class="page-bg">
    <div class="topbar">
        <span class="topbar-title">To-Do List</span>
        <span class="db-badge">SQL Server Connected</span>
    </div>

    <div class="content-area">
        <div class="stats-row">
            <div class="stat-card blue">
                <div class="stat-label">Total Tasks</div>
                <div class="stat-value">@tasks.Count</div>
            </div>
            <div class="stat-card green">
                <div class="stat-label">Completed</div>
                <div class="stat-value">@tasks.Count(t => t.IsComplete)</div>
            </div>
            <div class="stat-card red">
                <div class="stat-label">Pending</div>
                <div class="stat-value">@tasks.Count(t => !t.IsComplete)</div>
            </div>
        </div>

        <div class="input-card">
            <input type="text"
                   @bind="newTask"
                   @bind:event="oninput"
                   @onkeypress="HandleKeyPress"
                   placeholder="Enter a task and press Enter or click Add..."
                   class="task-input" />
            <button class="btn-add" @onclick="AddTask">+ Add Task</button>
            <button class="btn-clear" @onclick="ClearAll">Clear All</button>
        </div>

        @if (tasks.Count == 0)
        {
            <div class="empty-box">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="13" y2="13"/></svg>
                <p>No tasks yet. Add one above!</p>
            </div>
        }
        else
        {
            <div class="task-card">
                @foreach (var task in tasks)
                {
                    <div class="task-row @(task.IsComplete ? "done" : "")">
                        <input type="checkbox"
                               class="task-chk"
                               checked="@task.IsComplete"
                               @onchange="() => ToggleComplete(task)" />
                        <span class="task-text">@task.TaskDescription</span>
                        <span class="task-date">@task.CreatedAt.ToString("MMM dd, yyyy")</span>
                        <button class="btn-del" @onclick="() => DeleteTask(task)">Delete</button>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .page-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #f0f4ff 0%, #e8f5e9 100%);
    }
    .topbar {
        background: rgba(255,255,255,0.9);
        padding: 14px 28px;
        border-bottom: 1px solid rgba(0,0,0,0.07);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .topbar-title {
        font-size: 17px;
        font-weight: 600;
        color: #1a1a2e;
    }
    .db-badge {
        background: #4a90e2;
        color: white;
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 20px;
    }
    .content-area {
        padding: 28px;
        max-width: 860px;
        margin: 0 auto;
    }
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }
    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 16px 20px;
        border: 1px solid rgba(0,0,0,0.06);
    }
    .stat-label {
        font-size: 12px;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .stat-value {
        font-size: 28px;
        font-weight: 600;
        margin-top: 4px;
    }
    .stat-card.blue .stat-value { color: #4a90e2; }
    .stat-card.green .stat-value { color: #27ae60; }
    .stat-card.red .stat-value { color: #e74c3c; }
    .input-card {
        background: white;
        border-radius: 12px;
        padding: 16px;
        border: 1px solid rgba(0,0,0,0.06);
        display: flex;
        gap: 10px;
        margin-bottom: 16px;
        align-items: center;
    }
    .task-input {
        flex: 1;
        border: 1.5px solid #e8e8e8;
        border-radius: 8px;
        padding: 11px 16px;
        font-size: 14px;
        outline: none;
        transition: border 0.2s;
    }
    .task-input:focus { border-color: #4a90e2; }
    .btn-add {
        background: #4a90e2;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 11px 20px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        white-space: nowrap;
    }
    .btn-add:hover { background: #357abd; }
    .btn-clear {
        background: #e74c3c;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 11px 18px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        white-space: nowrap;
    }
    .btn-clear:hover { background: #c0392b; }
    .task-card {
        background: white;
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,0.06);
        overflow: hidden;
    }
    .task-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        border-bottom: 1px solid #f5f5f5;
        transition: background 0.15s;
    }
    .task-row:last-child { border-bottom: none; }
    .task-row:hover { background: #f8f9ff; }
    .task-row.done { background: #f6fff8; }
    .task-chk {
        width: 17px;
        height: 17px;
        cursor: pointer;
        accent-color: #27ae60;
        flex-shrink: 0;
    }
    .task-text {
        flex: 1;
        font-size: 14px;
        color: #2d2d2d;
    }
    .task-row.done .task-text {
        text-decoration: line-through;
        color: #bbb;
    }
    .task-date {
        font-size: 12px;
        color: #ccc;
        white-space: nowrap;
    }
    .btn-del {
        padding: 5px 14px;
        background: #fff0f0;
        color: #e74c3c;
        border: 1px solid #ffd0d0;
        border-radius: 6px;
        font-size: 12px;
        cursor: pointer;
    }
    .btn-del:hover { background: #ffe0e0; }
    .empty-box {
        text-align: center;
        padding: 50px 20px;
        background: white;
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,0.06);
        color: #ccc;
        font-size: 15px;
    }
    .empty-box p { margin-top: 12px; }
</style>

@code {
    private string newTask = "";
    private List<TaskItem> tasks = new();

    protected override void OnInitialized()
    {
        tasks = Db.Tasks.ToList();
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTask();
    }

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            var item = new TaskItem
            {
                TaskDescription = newTask.Trim(),
                IsComplete = false,
                CreatedAt = DateTime.Now
            };
            Db.Tasks.Add(item);
            Db.SaveChanges();
            tasks = Db.Tasks.ToList();
            newTask = "";
        }
    }

    private void ToggleComplete(TaskItem task)
    {
        task.IsComplete = !task.IsComplete;
        Db.Tasks.Update(task);
        Db.SaveChanges();
        tasks = Db.Tasks.ToList();
    }

    private void DeleteTask(TaskItem task)
    {
        Db.Tasks.Remove(task);
        Db.SaveChanges();
        tasks = Db.Tasks.ToList();
    }

    private void ClearAll()
    {
        Db.Tasks.RemoveRange(Db.Tasks);
        Db.SaveChanges();
        tasks.Clear();
    }
}